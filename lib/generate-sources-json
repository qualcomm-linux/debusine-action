# Run on the host

# Emits a JSON artifact describing the qli and qli-ci apt sources so that a
# downstream consumer (e.g. a GitHub listener) can download it and write the
# .sources files directly without scraping the human-facing step summary.

# Dependencies:
#   ca-certificates and curl packages: when you run this script
#   python3: for safe JSON construction

# Inputs:
#   DEBUSINE_HOST
#   DEBUSINE_SCOPE
#   DEBUSINE_USER
#   DEBUSINE_TOKEN
#   DEBUSINE_WORKSPACE
#   SUITE
#   OUTPUT (optional, defaults to sources.json)

: ${OUTPUT:=sources.json}

qli_uri="https://deb.${DEBUSINE_HOST}/${DEBUSINE_SCOPE}/qli/"
ci_uri="https://deb.${DEBUSINE_HOST}/${DEBUSINE_SCOPE}/${DEBUSINE_WORKSPACE}/"

qli_public_key=$(curl -fsSu "${DEBUSINE_USER}:${DEBUSINE_TOKEN}" "${qli_uri}signing-keys.asc")
ci_public_key=$(curl -fsSu "${DEBUSINE_USER}:${DEBUSINE_TOKEN}" "${ci_uri}signing-keys.asc")

QLI_URI="$qli_uri" CI_URI="$ci_uri" SUITE="$SUITE" \
QLI_KEY="$qli_public_key" CI_KEY="$ci_public_key" \
python3 - "$OUTPUT" <<'PY'
import json
import os
import sys

suite = os.environ["SUITE"]


def entry(filename, uri, key):
    indented_key = "\n".join(
        " " + line if line else " ."
        for line in key.splitlines()
    )
    content = (
        "Types: deb deb-src\n"
        f"URIs: {uri}\n"
        f"Suites: {suite}\n"
        "Components: main\n"
        "Signed-By:\n"
        f"{indented_key}\n"
    )
    return {
        "filename": filename,
        "types": "deb deb-src",
        "uris": uri,
        "suites": suite,
        "components": "main",
        "signed_by": key,
        "content": content,
    }


data = {
    "sources": [
        entry("qli.sources", os.environ["QLI_URI"], os.environ["QLI_KEY"]),
        entry("qli-ci.sources", os.environ["CI_URI"], os.environ["CI_KEY"]),
    ]
}

with open(sys.argv[1], "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY
