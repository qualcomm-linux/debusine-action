import json
import subprocess
import sys
import tempfile
from typing import Dict, List, Optional

# Default environment - change this constant to swap the default
DEFAULT_ENVIRONMENT = "production"

# Required reviewers for the Production environment
REQUIRED_REVIEWERS = ["basak-qcom", "gagath", "lool"]

# Environment to host mapping
ENVIRONMENT_HOSTS = {
    "production": "debusine.qualcomm.com",
    "stage": "stage.debusine.qualcomm.com",
}


def run_gh_command(args: List[str]) -> str:
    """Run a gh CLI command and return stdout. Raises CalledProcessError on failure."""
    result = subprocess.run(
        ["gh"] + args, capture_output=True, text=True, check=True
    )
    return result.stdout


def expand_repo_name(repo_name: str) -> str:
    """Expand repo name to full owner/repo format."""
    return f"qualcomm-linux/{repo_name}"


def check_gh_auth() -> bool:
    """Check if gh is authenticated."""
    try:
        run_gh_command(["auth", "status"])
        return True
    except subprocess.CalledProcessError:
        return False


def get_repo_info(repo: str) -> Dict:
    """Get repository metadata (default_branch, visibility, etc.)."""
    stdout = run_gh_command(["api", f"repos/{repo}"])
    return json.loads(stdout)


def get_repo_custom_properties(repo: str) -> Dict[str, str]:
    """Get repository custom properties as a name→value dict."""
    stdout = run_gh_command(["api", f"repos/{repo}/properties/values"])
    data = json.loads(stdout)
    return {item["property_name"]: item["value"] for item in data}


def get_environment(repo: str, env_name: str) -> Optional[Dict]:
    """Get environment details if it exists."""
    try:
        stdout = run_gh_command(
            ["api", f"repos/{repo}/environments/{env_name}"]
        )
        return json.loads(stdout)
    except subprocess.CalledProcessError:
        return None


def create_environment(repo: str, env_name: str, dry_run: bool) -> None:
    """Create an environment."""
    if dry_run:
        print(f"  Would create environment: {env_name}")
        return

    run_gh_command(
        ["api", f"repos/{repo}/environments/{env_name}", "-X", "PUT"]
    )


def get_repo_variables(repo: str) -> Dict[str, str]:
    """Get all repository-level variables."""
    stdout = run_gh_command(["api", f"repos/{repo}/actions/variables"])
    data = json.loads(stdout)
    return {var["name"]: var["value"] for var in data.get("variables", [])}


def set_repo_variable(repo: str, name: str, value: str, dry_run: bool) -> None:
    """Set a repository-level variable."""
    if dry_run:
        print(f"  Would set variable {name}={value}")
        return

    # Try to update first
    try:
        run_gh_command(
            [
                "api",
                f"repos/{repo}/actions/variables/{name}",
                "-X",
                "PATCH",
                "-f",
                f"value={value}",
            ]
        )
        return
    except subprocess.CalledProcessError:
        pass

    # If update failed, try to create
    run_gh_command(
        [
            "api",
            f"repos/{repo}/actions/variables",
            "-X",
            "POST",
            "-f",
            f"name={name}",
            "-f",
            f"value={value}",
        ]
    )


def delete_repo_variable(repo: str, name: str, dry_run: bool) -> None:
    """Delete a repository-level variable."""
    if dry_run:
        print(f"  Would delete variable {name}")
        return

    run_gh_command(
        ["api", f"repos/{repo}/actions/variables/{name}", "-X", "DELETE"]
    )


def get_user_id(username: str) -> int:
    """Get a GitHub user's numeric ID."""
    stdout = run_gh_command(["api", f"users/{username}"])
    data = json.loads(stdout)
    return data["id"]


def configure_repository(repo: str, debusine_host: str, dry_run: bool, force: bool = False) -> int:
    """
    Configure repository with required settings.
    Returns 0 if no changes needed, 1 if changes were made/needed.
    """
    changes_needed = False

    print(f"Configuring repository: {repo}")
    print(f"Using DEBUSINE_HOST: {debusine_host}")
    print()

    # Prerequisite checks
    print("Checking repository prerequisites...")
    prereq_failures = False

    repo_info = get_repo_info(repo)
    if repo_info.get("visibility") != "public":
        print(f"❌ Repository is not public (visibility: {repo_info.get('visibility', 'unknown')})")
        prereq_failures = True
    else:
        print("✓ Repository is public")

    props = get_repo_custom_properties(repo)
    if props.get("is-pkg-repo") != "true":
        current = props.get("is-pkg-repo", "unset")
        print(f"❌ Custom property 'is-pkg-repo' is not set to 'true' (current: {current})")
        prereq_failures = True
    else:
        print("✓ Custom property 'is-pkg-repo' is set to 'true'")

    if prereq_failures:
        if dry_run:
            print("Warning: Prerequisite checks failed. "
                  "Running without --check will fail unless --force is provided.")
        elif not force:
            print()
            print("Error: Prerequisite checks failed. Use --force to override.")
            return 1
        else:
            print("Warning: Prerequisite checks failed (proceeding due to --force).")
    print()

    # 0. Check default branch
    default_branch = repo_info["default_branch"]
    if default_branch != "qli-ci":
        print(
            f"❌ Default branch is '{default_branch}', must be 'qli-ci'"
        )
        return 1
    else:
        print("✓ Default branch is 'qli-ci'")
    print()

    # 1. Ensure Production and Staging environments exist
    print("Checking environments...")
    env = get_environment(repo, "Production")
    if env is None:
        print("❌ Environment 'Production' does not exist")
        changes_needed = True
        if not dry_run:
            create_environment(repo, "Production", dry_run)
            print("✓ Created environment 'Production'")
    else:
        print("✓ Environment 'Production' exists")

    env_staging = get_environment(repo, "Staging")
    if env_staging is None:
        print("❌ Environment 'Staging' does not exist")
        changes_needed = True
        if not dry_run:
            create_environment(repo, "Staging", dry_run)
            print("✓ Created environment 'Staging'")
    else:
        print("✓ Environment 'Staging' exists")

    print()

    # 2. Check and set required variables
    print("Checking repository variables...")
    variables = get_repo_variables(repo)

    required_vars = {
        "DEBUSINE_HOST": debusine_host,
        "DEBUSINE_SCOPE": "qualcomm",
    }

    for var_name, expected_value in required_vars.items():
        current_value = variables.get(var_name)
        if current_value != expected_value:
            print(
                f"❌ Variable {var_name} should be '{expected_value}' (currently: {current_value or 'unset'})"
            )
            changes_needed = True
            if not dry_run:
                set_repo_variable(repo, var_name, expected_value, dry_run)
                print(f"✓ Set {var_name}={expected_value}")
        else:
            print(f"✓ Variable {var_name} is correctly set")

    # 3. Ensure prohibited variable is not set
    prohibited_var = "DEBUSINE_PARENT_WORKSPACE"
    if prohibited_var in variables:
        print(
            f"❌ Variable {prohibited_var} should not be set (currently: {variables[prohibited_var]})"
        )
        changes_needed = True
        if not dry_run:
            delete_repo_variable(repo, prohibited_var, dry_run)
            print(f"✓ Deleted {prohibited_var}")
    else:
        print(f"✓ Variable {prohibited_var} is not set")

    print()

    # 4. Configure environment protection rules
    print("Checking environment protection rules...")

    # First ensure environment exists (might have just been created)
    env = get_environment(repo, "Production")
    if env is None:
        print(
            "✗ Cannot configure protection rules - environment does not exist"
        )
        return 1

    protection_rules = env.get("protection_rules", [])

    existing_reviewer_logins = []
    existing_reviewer_ids: Dict[str, int] = {}
    for rule in protection_rules:
        if rule.get("type") == "required_reviewers":
            for reviewer in rule.get("reviewers", []):
                login = reviewer.get("reviewer", {}).get("login")
                uid = reviewer.get("reviewer", {}).get("id")
                if login:
                    existing_reviewer_logins.append(login)
                    if uid:
                        existing_reviewer_ids[login] = uid

    can_admins_bypass = env.get("can_admins_bypass", True)

    missing_reviewers = [r for r in REQUIRED_REVIEWERS if r not in existing_reviewer_logins]
    needs_protection_update = bool(missing_reviewers) or can_admins_bypass

    for reviewer in REQUIRED_REVIEWERS:
        if reviewer in existing_reviewer_logins:
            print(f"✓ Required reviewer '{reviewer}' is configured")
        else:
            print(f"❌ Required reviewer '{reviewer}' is not configured")
            changes_needed = True

    if can_admins_bypass:
        print("❌ 'Allow administrators to bypass configured protection rules' is enabled (must be disabled)")
        changes_needed = True
    else:
        print("✓ Administrator bypass is disabled")

    if needs_protection_update and not dry_run:
        all_logins = list(existing_reviewer_logins)
        for login in missing_reviewers:
            all_logins.append(login)
        payload = {
            "reviewers": [
                {
                    "type": "User",
                    "id": existing_reviewer_ids.get(login) or get_user_id(login),
                }
                for login in all_logins
            ],
            "can_admins_bypass": False,
            "deployment_branch_policy": None,
        }
        with tempfile.NamedTemporaryFile(mode="w", suffix=".json") as f:
            json.dump(payload, f)
            f.flush()
            run_gh_command(
                [
                    "api",
                    f"repos/{repo}/environments/Production",
                    "-X",
                    "PUT",
                    "--input",
                    f.name,
                ]
            )
        for login in missing_reviewers:
            print(f"✓ Set required reviewer '{login}'")
        if can_admins_bypass:
            print("✓ Disabled administrator bypass")

    if needs_protection_update and dry_run:
        for login in missing_reviewers:
            print(f"  Would add required reviewer '{login}'")
        if can_admins_bypass:
            print("  Would disable administrator bypass")

    # Check Staging has no protection rules
    staging_env = get_environment(repo, "Staging")
    if staging_env is not None:
        staging_rules = staging_env.get("protection_rules", [])
        if staging_rules:
            rule_types = [r.get("type", "unknown") for r in staging_rules]
            print(f"❌ Environment 'Staging' has protection rules: {', '.join(rule_types)}")
            changes_needed = True
            if not dry_run:
                payload = {"reviewers": [], "deployment_branch_policy": None}
                with tempfile.NamedTemporaryFile(mode="w", suffix=".json") as f:
                    json.dump(payload, f)
                    f.flush()
                    run_gh_command([
                        "api", f"repos/{repo}/environments/Staging",
                        "-X", "PUT", "--input", f.name,
                    ])
                print("✓ Cleared protection rules from 'Staging' environment")
            else:
                print("  Would clear protection rules from 'Staging' environment")
        else:
            print("✓ Environment 'Staging' has no protection rules")

    print()

    if dry_run:
        if changes_needed:
            print("Summary: Changes are needed (run without --check to apply)")
            return 1
        else:
            print("Summary: Repository is correctly configured")
            return 0
    else:
        if changes_needed:
            print("Summary: Changes have been applied")
            return 0
        else:
            print("Summary: No changes were needed")
            return 0


def main():
    """Main entry point."""
    args = sys.argv[1:]

    if not args or args[0] in ["-h", "--help"]:
        print(__doc__)
        return 0

    dry_run = False
    force = False
    repo_name = None
    environment = DEFAULT_ENVIRONMENT

    for arg in args:
        if arg == "--check":
            dry_run = True
        elif arg == "--force":
            force = True
        elif arg == "--production":
            environment = "production"
        elif arg == "--stage":
            environment = "stage"
        elif not arg.startswith("-"):
            repo_name = arg

    if not repo_name:
        print("Error: Repository name is required", file=sys.stderr)
        print(__doc__)
        return 1

    # Get the debusine host for the selected environment
    debusine_host = ENVIRONMENT_HOSTS[environment]

    # Check gh authentication
    if not check_gh_auth():
        print(
            "Error: gh is not authenticated. Run 'gh auth login' first.",
            file=sys.stderr,
        )
        return 1

    # Expand repo name
    full_repo = expand_repo_name(repo_name)

    # Configure repository
    return configure_repository(full_repo, debusine_host, dry_run, force)


if __name__ == "__main__":
    sys.exit(main())
