#!/usr/bin/env python3
"""
Configure a GitHub repository with required settings for debusine-action workflows.

Usage:
    configure-repo [--check] [--force] [--production | --stage] <repo-name>

Arguments:
    repo-name    Repository name with pkg- prefix (e.g., 'pkg-fastrpc' expands to 'qualcomm-linux/pkg-fastrpc')

Options:
    --check         Only report what needs changing without making changes
    --force         Proceed even if prerequisite checks fail (visibility, is-pkg-repo)
    --production    Set DEBUSINE_HOST to debusine.qualcomm.com (default)
    --stage         Set DEBUSINE_HOST to stage.debusine.qualcomm.com
"""

