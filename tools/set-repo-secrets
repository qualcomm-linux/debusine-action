#!/usr/bin/env python3
"""
Set secrets for a GitHub repository required by debusine-action workflows.

This tool prompts for secrets and sets them appropriately:
- DEBUSINE_USER: repository-level secret
- DEBUSINE_TOKEN: repository-level secret
- DEBUSINE_RELEASE_TOKEN: environment-level secret (Production environment)
- DEBUSINE_RELEASE_TOKEN: environment-level secret (Staging environment)

Usage:
    set-repo-secrets <repo-name>

Arguments:
    repo-name    Repository name with pkg- prefix (e.g., 'pkg-fastrpc' expands to 'qualcomm-linux/pkg-fastrpc')
"""

# Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
# SPDX-License-Identifier: BSD-3-Clause-Clear

import getpass
import subprocess
import sys
from typing import List


def run_gh_command(args: List[str]) -> str:
    """Run a gh CLI command and return stdout. Raises CalledProcessError on failure."""
    result = subprocess.run(
        ["gh"] + args, capture_output=True, text=True, check=True
    )
    return result.stdout


def expand_repo_name(repo_name: str) -> str:
    """Expand repo name to full owner/repo format."""
    return f"qualcomm-linux/{repo_name}"


def check_gh_auth() -> bool:
    """Check if gh is authenticated."""
    try:
        run_gh_command(["auth", "status"])
        return True
    except subprocess.CalledProcessError:
        return False


def set_repo_secret(repo: str, secret_name: str, secret_value: str) -> None:
    """Set a repository-level secret."""
    # Use gh secret set with stdin
    subprocess.run(
        ["gh", "secret", "set", secret_name, "-R", repo],
        input=secret_value,
        text=True,
        capture_output=True,
        check=True,
    )


def set_environment_secret(
    repo: str, env_name: str, secret_name: str, secret_value: str
) -> None:
    """Set an environment-level secret."""
    # Use gh secret set with environment flag
    subprocess.run(
        ["gh", "secret", "set", secret_name, "-R", repo, "-e", env_name],
        input=secret_value,
        text=True,
        capture_output=True,
        check=True,
    )


def prompt_for_secret(secret_name: str, env_name: str = None, default: str = None) -> str:
    """Prompt user for a secret value."""
    label = f"{secret_name} ({env_name} environment)" if env_name else secret_name
    if default:
        label = f"{label} [{default}]"
    while True:
        value = getpass.getpass(f"Enter value for {label}: ")
        if value:
            return value
        if default:
            return default
        print("Error: Secret value cannot be empty. Please try again.")


def set_secrets(repo: str) -> int:
    """
    Prompt for and set all required secrets.
    Returns 0 on success, 1 on failure.
    """
    print(f"Setting secrets for repository: {repo}")
    print()

    # Define secrets to set
    repo_secrets = [
        (
            "DEBUSINE_USER",
            "Repository secret for Debusine user",
        ),
        (
            "DEBUSINE_TOKEN",
            "Repository secret for Debusine API authentication",
        ),
    ]

    env_secrets = [
        (
            "DEBUSINE_RELEASE_TOKEN",
            "Production",
            "Environment secret for Debusine release operations",
        ),
        (
            "DEBUSINE_RELEASE_TOKEN",
            "Staging",
            "Environment secret for Debusine release operations",
        ),
    ]

    # Set repository-level secrets
    print("Repository-level secrets:")
    secret_defaults = {
        "DEBUSINE_USER": "DebusineGitHubCI@qualcomm.com",
    }
    for secret_name, description in repo_secrets:
        print(f"\n{description}")
        secret_value = prompt_for_secret(secret_name, default=secret_defaults.get(secret_name))
        set_repo_secret(repo, secret_name, secret_value)
        print(f"✓ Set {secret_name}")

    # Set environment-level secrets
    print("\n\nEnvironment-level secrets:")
    for secret_name, env_name, description in env_secrets:
        print(f"\n{description}")
        secret_value = prompt_for_secret(secret_name, env_name=env_name)
        set_environment_secret(repo, env_name, secret_name, secret_value)
        print(f"✓ Set {secret_name} in {env_name} environment")

    print("\n✓ All secrets have been set successfully")
    return 0


def main():
    """Main entry point."""
    args = sys.argv[1:]

    if not args or args[0] in ["-h", "--help"]:
        print(__doc__)
        return 0

    repo_name = args[0]

    # Check gh authentication
    if not check_gh_auth():
        print(
            "Error: gh is not authenticated. Run 'gh auth login' first.",
            file=sys.stderr,
        )
        return 1

    # Expand repo name
    full_repo = expand_repo_name(repo_name)

    # Set secrets
    return set_secrets(full_repo)


if __name__ == "__main__":
    sys.exit(main())
